# Android Studio / IntelliJ IDEA
*.iml
.idea/

# Gradle 与各模块构建产物
.gradle/
**/build/

# 本机 Android SDK 配置
local.properties

# Native 构建产物
.externalNativeBuild/
.cxx/

# 测试、截图与系统文件
captures/
/test/
.DS_Store
~$*.pptx
~$*.xlsx
~$*.docx

# 外部开源参考仓库仅供本地阅读，不纳入本项目版本控制
references/open_source/

# 课程原始 Word 材料保留在本地；Git 中维护对应 Markdown 文档
docs/*.docx

# 含人物的本地真实测试图片不上传公开仓库
test_pic/

# 演示视频体积超过 GitHub 单文件限制，仅保留封面和发布说明
/demo/*.mp4
/demo/*.mov
